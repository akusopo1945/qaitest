{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qaitest.test/schemas/qa-plan.schema.json",
  "title": "Qaitest QA Plan",
  "type": "object",
  "required": ["id", "title", "objective", "base_url", "steps"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "provider_hint": {
      "type": "string"
    },
    "base_url": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high", "critical"]
    },
    "preconditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "input_data": {
      "type": "object",
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "navigate",
              "fill",
              "click",
              "select",
              "wait_for",
              "assert_text",
              "assert_visible",
              "assert_count",
              "confirm_dialog",
              "screenshot",
              "custom"
            ]
          },
          "url": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "value_ref": {
            "type": "string"
          },
          "contains_ref": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "timeout_ms": {
            "type": "integer",
            "minimum": 1
          },
          "description": {
            "type": "string"
          },
          "accept": {
            "type": "boolean"
          }
        }
      }
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "additionalProperties": true
      }
    },
    "cleanup": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "reporting": {
      "type": "object",
      "additionalProperties": true
    },
    "ai_summary": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
